{
    "name": "ghanem/google-map",
    "description": "Google Map with Places Autocomplete field for Laravel Nova 4 & 5.",
    "keywords": [
        "laravel",
        "nova",
        "nova 4",
        "nova 5",
        "google map",
        "google places",
        "autocomplete",
        "geocoding"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "laravel/nova": "^4.0|^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ghanem\\GoogleMap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ghanem\\GoogleMap\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ghanem\\GoogleMap\\FieldServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
